/* Mova para a linha 1 do index.css */
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* ─── LANDING PAGE THEME (Rose Gold / Spa) ─── */
    --background: 240 10% 99%;      /* off-white */
    --foreground: 240 10% 10%;      /* charcoal */

    --card: 0 0% 100%;
    --card-foreground: 240 10% 10%;

    --popover: 0 0% 100%;
    --popover-foreground: 240 10% 10%;

    --primary: 350 35% 58%;         /* Rose Gold #B76E79 */
    --primary-foreground: 0 0% 100%;

    --secondary: 40 45% 95%;        /* Creamy backdrop */
    --secondary-foreground: 350 35% 30%;

    --muted: 240 5% 96%;
    --muted-foreground: 240 4% 46%;

    --accent: 43 65% 53%;           /* Champagne #D4AF37 */
    --accent-foreground: 0 0% 100%;

    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 0 0% 100%;

    --border: 240 6% 90%;
    --input: 240 6% 90%;
    --ring: 350 35% 58%;

    --radius: 2rem;                 /* Rounded for LP */

    --premium-gradient: linear-gradient(135deg, #B76E79, #D4AF37);
    --shadow-premium: 0 10px 30px -10px rgba(183, 110, 121, 0.3);
    
    --font-display: 'Playfair Display', serif;
    --font-body: 'Inter', sans-serif;
  }

  /*
  .dashboard-theme {
    --background: 210 10% 96%;
    --foreground: 210 10% 20%;
    --card: 0 0% 100%;
    --card-foreground: 210 10% 20%;
    --popover: 0 0% 100%;
